# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# NEVER hardcode this - always use environment variables!
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# OPENROUTER_API_KEY: Optional, for OpenRouter API calls
# NEVER hardcode this - always set via environment variables!
# For local development: Create .env.local (NOT tracked by git)
# For production: Set via Vercel/deployment platform environment variables
OPENROUTER_API_KEY="YOUR_OPENROUTER_KEY_HERE"

# MINIMAX_API_KEY: For MiniMax API calls (Anthropic-compatible)
# NEVER hardcode this - always use environment variables!
MINIMAX_API_KEY="YOUR_MINIMAX_API_KEY_HERE"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:5173"

# SECURITY NOTES:
# ================
# 1. NEVER commit .env files to version control
# 2. NEVER hardcode API keys in source code
# 3. ALWAYS use environment variables (process.env or import.meta.env)
# 4. Use .env.local for local development (already in .gitignore)
# 5. Rotate API keys immediately if accidentally committed
# 6. Use git-filter-branch to remove exposed keys from history
