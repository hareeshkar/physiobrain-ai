# MINIMAX_API_KEY: Required for MiniMax AI API calls.
# Get your key from https://console.minimax.io
# This is the ONLY API key needed for PhysioBrain AI
MINIMAX_API_KEY="YOUR_MINIMAX_API_KEY_HERE"

# APP_URL: The URL where this applet is hosted.
# For local development: http://localhost:5173
# For production: Your Vercel deployment URL
APP_URL="http://localhost:5173"

# SECURITY NOTES:
# ================
# 1. NEVER commit .env files to version control
# 2. NEVER hardcode API keys in source code
# 3. ALWAYS use environment variables
# 4. Use .env.local for local development (already in .gitignore)
# 5. Rotate API keys immediately if accidentally committed
